<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_comments"
    android:padding="10dp"
    android:layout_marginTop="8dp"
    android:id="@+id/parentlayout">
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <LinearLayout
            android:orientation="horizontal"
            android:layout_alignParentLeft="true"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">

            <de.hdodenhof.circleimageview.CircleImageView
                android:id="@+id/ivProfile"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:src="@drawable/ic_image"
                />
            <TextView
                android:layout_gravity="center"
                android:id="@+id/tvName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_toRightOf="@id/ivProfile"
                android:text="Maggie Phillips"
                android:textColor="@color/black"
                android:fontFamily="@font/roboto_medium"
                android:textSize="14sp"
                android:layout_marginLeft="10dp"/>
        </LinearLayout>

        <TextView
            android:visibility="invisible"
            android:id="@+id/tvTime"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:text="5h ago"
            android:layout_centerVertical="true"
            android:textColor="@color/Lite_Gray"
            android:textSize="12sp"
            android:layout_marginRight="5dp"
            />

        <LinearLayout
            android:id="@+id/approvalStatusLayout"
            android:layout_centerInParent="true"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_alignParentRight="true">

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnReject"
                android:layout_width="wrap_content"
                android:layout_height="@dimen/_24sdp"
                android:text="Reject"
                android:background="@drawable/bg_reject"
                android:textColor="@color/white"
                android:textSize="8sp"
                android:drawableLeft="@drawable/ic_reject"
                android:paddingLeft="10dp"
                android:layout_marginRight="5dp"
                />
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnApprove"
                android:layout_width="wrap_content"
                android:layout_height="@dimen/_24sdp"
                android:text="Approve"
                android:background="@drawable/bg_approve"
                android:textColor="@color/white"
                android:textSize="8sp"
                android:drawableLeft="@drawable/ic_approve"
                android:paddingLeft="10dp"
                android:layout_marginRight="5dp"
                />
        </LinearLayout>
    </RelativeLayout>
    <TextView
        android:id="@+id/tvCaption"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Post Caption"
        android:textColor="@color/Dark_Gray"
        android:textSize="12sp"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="10dp"
        />
    <ImageView
        android:id="@+id/ivImagePost"
        android:background="@color/black"
        android:layout_width="match_parent"
        android:layout_height="200dp"

        android:src="@drawable/ic_image2"/>
    <RelativeLayout
        android:layout_marginTop="10dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <LinearLayout
            android:id="@+id/llCommentIcon"
            android:layout_centerInParent="true"
            android:layout_alignParentLeft="true"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <ImageView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/ic_comment"/>
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <TextView
                    android:id="@+id/tvCommentCount"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="@color/Dark_Gray"
                    android:textSize="12sp"
                    android:layout_marginLeft="10dp"
                    android:layout_marginRight="10dp"
                    android:layout_gravity="center"
                    />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="comment"></TextView>
            </LinearLayout>
        </LinearLayout>
        <androidx.appcompat.widget.AppCompatRatingBar
            android:layout_centerInParent="true"
            style="?android:attr/ratingBarStyleSmall"
            android:id="@+id/ratingBarPost"
            android:background="@color/white"
            android:layout_marginRight="14dp"
            android:layout_alignParentRight="true"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:theme="@style/RatingBar"
            ></androidx.appcompat.widget.AppCompatRatingBar>
    </RelativeLayout>
</LinearLayout>